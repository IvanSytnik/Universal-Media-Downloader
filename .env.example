# Скопируй этот файл в .env и заполни реальными значениями.
# cp .env.example .env

ENVIRONMENT=local
LOG_LEVEL=INFO

# Получить токен у @BotFather в Telegram
BOT_TOKEN=123456:REPLACE_WITH_REAL_TOKEN

# --- Локальный Telegram Bot API сервер (Day 6) ---
# Нужен, только если хочешь отправлять файлы больше 50 МБ (лимит
# api.telegram.org). Бесплатная регистрация приложения на
# https://my.telegram.org/apps — НЕ токен бота, отдельная пара.
# Если не собираешься качать большие видео — оставь USE_LOCAL_BOT_API=false,
# остальные две переменные тогда можно не заполнять.
TELEGRAM_API_ID=REPLACE_WITH_YOUR_API_ID
TELEGRAM_API_HASH=REPLACE_WITH_YOUR_API_HASH
USE_LOCAL_BOT_API=false
LOCAL_BOT_API_BASE_URL=http://telegram-bot-api:8081

# Лимит на размер файла, который бот пытается отправить (в МБ).
# 50 — стандартный лимит Telegram без локального сервера.
# Если USE_LOCAL_BOT_API=true, можно поднять до 2000.
MAX_DELIVERABLE_FILE_SIZE_MB=50

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=umd
POSTGRES_USER=umd
POSTGRES_PASSWORD=umd

# Порты, на которых Postgres/Redis торчат наружу из Docker (для psql/redis-cli
# с хоста). Не путать с POSTGRES_PORT/REDIS_PORT выше — те используются
# внутри Docker-сети между контейнерами и почти никогда не должны меняться.
# Если 5433/6380 тоже заняты — поменяй здесь.
HOST_POSTGRES_PORT=5433
HOST_REDIS_PORT=6380

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
